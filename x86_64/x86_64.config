#设备平台
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
#设备列表
CONFIG_TARGET_ALL_PROFILES=y
#组件调整
CONFIG_GRUB_IMAGES=y
CONFIG_VMDK_IMAGES=y
CONFIG_TARGET_KERNEL_PARTSIZE=128
CONFIG_TARGET_ROOTFS_PARTSIZE=2048
CONFIG_TARGET_ROOTFS_EXT4FS=n

# 代理插件
CONFIG_PACKAGE_luci-app-ssr-plus=n
CONFIG_PACKAGE_luci-app-openclash=y

# passwall 1/2 编译

# #之后不带空格的按需编译。Shadowsocks_Rust Shadow_TLS可以取消编译，会调用 rust，增加编译时间
CONFIG_PACKAGE_luci-app-passwall=y
# 按需选择。一般情况，按照个人使用习惯，编译 xing-box & xray之一，使其不影响正常使用
# xray和singbox 默认编译，如果要取消编译，就在 #后面添加空格，反之则是编译
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox is not set
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray is not set

#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Geoview is not set
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy is not set
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria is not set
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_NaiveProxy is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Server is not set
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client is not set
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Server is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Server is not set
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Simple_Obfs is not set
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadow_TLS is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan_Plus is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_tuic_client is not set
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Geodata is not set
#CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray_Plugin is not set

# passwall2编译
# #之后不带空格的按需编译。Shadowsocks_Rust Shadow_TLS可以取消编译，会调用 rust，增加编译时间
# passwall 1/2 不同时编译的话请按需编译需要的插件，以免不能满足使用
CONFIG_PACKAGE_luci-app-passwall2=y
# 按需选择。一般情况，按照个人使用习惯，编译 xing-box & xray之一，使其不影响正常使用
# xray和singbox 默认编译，如果要取消编译，就在 #后面添加空格，反之则是编译
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_SingBox is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Xray is not set

# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Haproxy is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Hysteria is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_NaiveProxy is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Libev_Client is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Libev_Server is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Client is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Server is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_ShadowsocksR_Libev_Client is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_ShadowsocksR_Libev_Server is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Simple_Obfs is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_tuic_client is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_V2ray_Plugin is not set

CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-dockerman=y
# CONFIG_PACKAGE_luci-app-poweroffdevice=y  #关机
# CONFIG_PACKAGE_luci-app-rtp2httpd=y  #IPTV 流媒体转发服务器
CONFIG_PACKAGE_luci-app-lucky=y  # lucky ddns+socat
# CONFIG_PACKAGE_luci-app-mosdns=y
# CONFIG_PACKAGE_luci-app-smartdns=y
# CONFIG_PACKAGE_luci-app-openlist2=y
CONFIG_PACKAGE_luci-app-quickfile=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-firewall=y
# CONFIG_PACKAGE_luci-app-owq-wol=y  #网络唤醒

# 安全防护
CONFIG_PACKAGE_luci-app-authshield=y
# CONFIG_PACKAGE_luci-app-watchdog=y  #看门狗
# CONFIG_PACKAGE_luci-app-taskplan=y  #任务设置2.0版

# vpn
# CONFIG_PACKAGE_luci-app-vnt=y
# CONFIG_PACKAGE_luci-app-easytier=y
# CONFIG_PACKAGE_luci-app-zerotier=y
# CONFIG_PACKAGE_luci-app-tailscale-community=y
# CONFIG_PACKAGE_luci-app-wireguard=y
# CONFIG_PACKAGE_luci-proto-wireguard=y
# CONFIG_PACKAGE_wireguard-tools=y

# 网络分享
CONFIG_PACKAGE_autosamba=n
CONFIG_PACKAGE_luci-app-samba4=n
CONFIG_PACKAGE_luci-app-cifs-mount=n #挂载 SMB 网络共享
# CONFIG_PACKAGE_luci-app-vsftpd=y #FTP服务器
# CONFIG_PACKAGE_autoksmbd=y
# CONFIG_PACKAGE_luci-app-ksmbd=y
# CONFIG_PACKAGE_ksmbd-hotplug=y  #插入 U 盘或移动硬盘时，自动你触发挂载和共享脚本
# CONFIG_PACKAGE_ksmbd-avahi-service=y  #用于“网络发现”。开启后，你的 Windows 电脑、苹果电脑或手机在“网上邻居”里能直接搜到这台路由器

# Themes
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-aurora=y
CONFIG_PACKAGE_luci-app-aurora-config=y
CONFIG_PACKAGE_luci-theme-bootstrap=n
# CONFIG_PACKAGE_luci-theme-kucat=y
# CONFIG_PACKAGE_luci-app-kucat-config=y

# 删除插件
# CONFIG_PACKAGE_luci-app-wol is not set
# CONFIG_PACKAGE_luci-app-ddns is not set
# CONFIG_PACKAGE_luci-app-xlnetacc is not set
# CONFIG_PACKAGE_vlmcsd is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set    # kms
# CONFIG_PACKAGE_luci-app-unblockmusic is not set
