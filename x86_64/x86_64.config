# CONFIG_PACKAGE_ksmbd-avahi-service=y  #用于“网络发现”。开启后，你的 Windows 电脑、苹果电脑或手机在“网上邻居”里能直接搜到这台路由器

# Themes
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-aurora=y
CONFIG_PACKAGE_luci-app-aurora-config=y
CONFIG_PACKAGE_luci-theme-bootstrap=n
# CONFIG_PACKAGE_luci-theme-kucat=y
# CONFIG_PACKAGE_luci-app-kucat-config=y

# 删除插件
